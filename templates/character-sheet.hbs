<div class="scp2e-sheet">

  {{!-- Header: identity + PDF import --}}
  <header class="scp2e-header">
    <div class="scp2e-logo"><span class="scp2e-mark">SCP</span></div>
    <div class="scp2e-identity">
      <div class="id-row">
        <label>{{localize "SCP2E.Field.Character"}}</label>
        <input type="text" name="name" value="{{actor.name}}" placeholder="—"/>
      </div>
      <div class="id-row">
        <label>{{localize "SCP2E.Field.Player"}}</label>
        <input type="text" name="flags.scp2e-character-sheet.data.identity.player" value="{{data.identity.player}}"/>
      </div>
      <div class="id-grid">
        <div><label>{{localize "SCP2E.Field.Title"}}</label>
          <input type="text" name="flags.scp2e-character-sheet.data.identity.title" value="{{data.identity.title}}"/></div>
        <div><label>{{localize "SCP2E.Field.PersonnelClass"}}</label>
          <input type="text" name="flags.scp2e-character-sheet.data.identity.personnelClass" value="{{data.identity.personnelClass}}"/></div>
        <div><label>{{localize "SCP2E.Field.Age"}}</label>
          <input type="text" name="flags.scp2e-character-sheet.data.identity.age" value="{{data.identity.age}}"/></div>
        <div><label>{{localize "SCP2E.Field.SecurityLevel"}}</label>
          <input type="text" name="flags.scp2e-character-sheet.data.identity.securityLevel" value="{{data.identity.securityLevel}}"/></div>
      </div>
    </div>
    <div class="scp2e-header-actions">
      <button type="button" data-action="importPdf" title="{{localize 'SCP2E.Import.Button'}}">
        <i class="fa-solid fa-file-import"></i> {{localize "SCP2E.Import.Button"}}
      </button>
    </div>
  </header>

  {{!-- Tab navigation --}}
  <nav class="scp2e-tabs">
    {{#each tabs}}
      <a class="scp2e-tab {{#if active}}active{{/if}}" data-action="changeTab" data-tab="{{id}}">
        <i class="{{icon}}"></i> {{localize label}}
      </a>
    {{/each}}
  </nav>

  <section class="tab-body">

  {{!-- ============================ MAIN ============================ --}}
  {{#if (eq activeTab "main")}}
  <div class="scp2e-main">
    <div class="attr-columns">
      <div class="attr-group">
        <h3 class="grp-physical">{{localize "SCP2E.Group.Physical"}}</h3>
        {{#each physical}}
          <div class="attr-box">
            <div class="attr-head">
              <button type="button" class="roll-btn" data-action="rollAttribute" data-attr="{{key}}" title="{{localize 'SCP2E.Roll.Attribute'}}"><i class="fa-solid fa-dice-d20"></i></button>
              <span class="attr-label">{{label}}</span>
              <span class="attr-abbr">{{abbr}}</span>
              <input type="number" class="attr-rating" name="flags.scp2e-character-sheet.data.attributes.{{key}}.value" value="{{value}}" min="0" title="{{localize 'SCP2E.Roll.Rating'}}"/>
            </div>
            <div class="attr-pool">
              <label>d6</label><input type="number" name="flags.scp2e-character-sheet.data.attributes.{{key}}.dice.d6" value="{{dice.d6}}" min="0"/>
              <label>d8</label><input type="number" name="flags.scp2e-character-sheet.data.attributes.{{key}}.dice.d8" value="{{dice.d8}}" min="0"/>
              <label>d10</label><input type="number" name="flags.scp2e-character-sheet.data.attributes.{{key}}.dice.d10" value="{{dice.d10}}" min="0"/>
              <label>d12</label><input type="number" name="flags.scp2e-character-sheet.data.attributes.{{key}}.dice.d12" value="{{dice.d12}}" min="0"/>
            </div>
          </div>
        {{/each}}
      </div>
      <div class="attr-group">
        <h3 class="grp-mental">{{localize "SCP2E.Group.Mental"}}</h3>
        {{#each mental}}
          <div class="attr-box">
            <div class="attr-head">
              <button type="button" class="roll-btn" data-action="rollAttribute" data-attr="{{key}}" title="{{localize 'SCP2E.Roll.Attribute'}}"><i class="fa-solid fa-dice-d20"></i></button>
              <span class="attr-label">{{label}}</span>
              <span class="attr-abbr">{{abbr}}</span>
              <input type="number" class="attr-rating" name="flags.scp2e-character-sheet.data.attributes.{{key}}.value" value="{{value}}" min="0" title="{{localize 'SCP2E.Roll.Rating'}}"/>
            </div>
            <div class="attr-pool">
              <label>d6</label><input type="number" name="flags.scp2e-character-sheet.data.attributes.{{key}}.dice.d6" value="{{dice.d6}}" min="0"/>
              <label>d8</label><input type="number" name="flags.scp2e-character-sheet.data.attributes.{{key}}.dice.d8" value="{{dice.d8}}" min="0"/>
              <label>d10</label><input type="number" name="flags.scp2e-character-sheet.data.attributes.{{key}}.dice.d10" value="{{dice.d10}}" min="0"/>
              <label>d12</label><input type="number" name="flags.scp2e-character-sheet.data.attributes.{{key}}.dice.d12" value="{{dice.d12}}" min="0"/>
            </div>
          </div>
        {{/each}}
      </div>
    </div>

    <div class="vitals">
      <div class="vital hp">
        <label>{{localize "SCP2E.Field.HP"}}</label>
        <input type="number" name="flags.scp2e-character-sheet.data.health.hp" value="{{data.health.hp}}"/>
        <span class="sep">/</span>
        <input type="number" name="flags.scp2e-character-sheet.data.health.maxHp" value="{{data.health.maxHp}}"/>
      </div>
      <div class="vital"><label>{{localize "SCP2E.Field.BaseHP"}}</label>
        <input type="number" name="flags.scp2e-character-sheet.data.health.baseHp" value="{{data.health.baseHp}}"/></div>
      <div class="vital"><label>{{localize "SCP2E.Field.DR"}}</label>
        <input type="number" name="flags.scp2e-character-sheet.data.health.dr" value="{{data.health.dr}}"/></div>
      <div class="vital"><label>{{localize "SCP2E.Field.HTHx"}}</label>
        <input type="text" name="flags.scp2e-character-sheet.data.health.hthMult" value="{{data.health.hthMult}}"/></div>
      <div class="vital"><label>{{localize "SCP2E.Field.BaseSpeed"}}</label>
        <input type="number" name="flags.scp2e-character-sheet.data.combat.baseSpeed" value="{{data.combat.baseSpeed}}"/></div>
    </div>

    <div class="tracks">
      <div class="track">
        <label>{{localize "SCP2E.Field.Exertion"}}</label>
        <button type="button" data-action="adjustTrack" data-track="exertion" data-delta="-1">−</button>
        <span class="track-val">{{data.tracks.exertion}}</span>
        <button type="button" data-action="adjustTrack" data-track="exertion" data-delta="1">+</button>
        <span class="sep">/</span>
        <input type="number" class="track-total" name="flags.scp2e-character-sheet.data.tracks.exertionTotal" value="{{data.tracks.exertionTotal}}" min="0" title="{{localize 'SCP2E.Field.ExertionTotal'}}"/>
      </div>
      <div class="track">
        <label>{{localize "SCP2E.Field.Reverence"}}</label>
        <button type="button" data-action="adjustTrack" data-track="reverence" data-delta="-1">−</button>
        <span class="track-val">{{data.tracks.reverence}}</span>
        <button type="button" data-action="adjustTrack" data-track="reverence" data-delta="1">+</button>
      </div>
    </div>

    <div class="disruption">
      <label>{{localize "SCP2E.Field.DisruptionClass"}}</label>
      <select name="flags.scp2e-character-sheet.data.identity.disruptionClass">
        <option value="">—</option>
        {{#each disruptionClasses as |d key|}}
          <option value="{{key}}" {{#if (eq ../data.identity.disruptionClass key)}}selected{{/if}}>{{d.label}} ({{d.ratio}})</option>
        {{/each}}
      </select>
      <label class="chapters">{{localize "SCP2E.Field.ChaptersSurvived"}}</label>
      <input type="number" name="flags.scp2e-character-sheet.data.identity.chaptersSurvived" value="{{data.identity.chaptersSurvived}}" min="0"/>
    </div>
  </div>
  {{/if}}

  {{!-- ============================ SKILLS ============================ --}}
  {{#if (eq activeTab "skills")}}
  <div class="scp2e-skills">
    <h3>{{localize "SCP2E.Skills.Crucial"}}</h3>
    <div class="skill-list">
      {{#each crucialSkills}}
        <div class="skill-row crucial">
          <button type="button" class="roll-btn sm" data-action="rollSkill" data-skill="{{key}}" title="{{localize 'SCP2E.Roll.Skill'}}"><i class="fa-solid fa-dice-d20"></i></button>
          <span class="skill-name">{{label}}</span>
          <span class="skill-gov">{{gov}}</span>
          <input type="number" name="flags.scp2e-character-sheet.data.skills.{{key}}.value" value="{{value}}" min="0"/>
          <input type="number" class="skill-mult" name="flags.scp2e-character-sheet.data.skills.{{key}}.mult" value="{{mult}}" min="1" max="3" title="{{localize 'SCP2E.Skills.Mult'}}"/>
          <span class="skill-cap" title="{{localize 'SCP2E.Skills.Cap'}}">/{{cap}}</span>
        </div>
      {{/each}}
    </div>

    <h3>{{localize "SCP2E.Skills.Standard"}}</h3>
    <div class="skill-list two-col">
      {{#each standardSkills}}
        <div class="skill-row">
          <button type="button" class="roll-btn sm" data-action="rollSkill" data-skill="{{key}}" title="{{localize 'SCP2E.Roll.Skill'}}"><i class="fa-solid fa-dice-d20"></i></button>
          <span class="skill-name">{{label}}</span>
          <span class="skill-gov">{{gov}}</span>
          <input type="number" name="flags.scp2e-character-sheet.data.skills.{{key}}.value" value="{{value}}" min="0"/>
          <input type="number" class="skill-mult" name="flags.scp2e-character-sheet.data.skills.{{key}}.mult" value="{{mult}}" min="1" max="3" title="{{localize 'SCP2E.Skills.Mult'}}"/>
          <span class="skill-cap" title="{{localize 'SCP2E.Skills.Cap'}}">/{{cap}}</span>
        </div>
      {{/each}}
    </div>

    <h3>{{localize "SCP2E.Skills.Custom"}}
      <button type="button" class="add-row" data-action="addCustomSkill" data-array="customSkills">
        <i class="fa-solid fa-plus"></i></button>
    </h3>
    <div class="skill-list">
      {{#each data.customSkills as |skill i|}}
        <div class="skill-row custom">
          <input type="text" class="custom-name" name="flags.scp2e-character-sheet.data.customSkills.{{i}}.name" value="{{skill.name}}" placeholder="{{localize 'SCP2E.Skills.CustomName'}}"/>
          <input type="text" class="custom-gov" name="flags.scp2e-character-sheet.data.customSkills.{{i}}.gov" value="{{skill.gov}}" placeholder="ATTR"/>
          <input type="number" name="flags.scp2e-character-sheet.data.customSkills.{{i}}.value" value="{{skill.value}}" min="0"/>
          <button type="button" class="del-row" data-action="deleteCustomSkill" data-array="customSkills" data-index="{{i}}"><i class="fa-solid fa-trash"></i></button>
        </div>
      {{/each}}
    </div>
  </div>
  {{/if}}

  {{!-- ============================ COMBAT ============================ --}}
  {{#if (eq activeTab "combat")}}
  <div class="scp2e-combat">
    <div class="combat-derived">
      <div><label>{{localize "SCP2E.Field.Speed"}}</label>
        <input type="text" name="flags.scp2e-character-sheet.data.combat.speed" value="{{data.combat.speed}}"/></div>
      <div><label>{{localize "SCP2E.Field.Combat"}}</label>
        <input type="text" name="flags.scp2e-character-sheet.data.combat.combat" value="{{data.combat.combat}}"/></div>
      <div><label>{{localize "SCP2E.Field.Projectile"}}</label>
        <input type="text" name="flags.scp2e-character-sheet.data.combat.projectile" value="{{data.combat.projectile}}"/></div>
      <div><label>{{localize "SCP2E.Field.Reaction"}}</label>
        <input type="text" name="flags.scp2e-character-sheet.data.combat.reaction" value="{{data.combat.reaction}}"/></div>
      <div><label>{{localize "SCP2E.Field.Stagger"}}</label>
        <input type="text" name="flags.scp2e-character-sheet.data.combat.stagger" value="{{data.combat.stagger}}"/></div>
    </div>

    <h3>{{localize "SCP2E.Weapons.Title"}}
      <button type="button" class="add-row" data-action="addWeapon" data-array="weapons"><i class="fa-solid fa-plus"></i></button>
    </h3>
    <table class="weapons">
      <thead><tr>
        <th>{{localize "SCP2E.Weapons.Name"}}</th><th>{{localize "SCP2E.Weapons.ToHit"}}</th>
        <th>{{localize "SCP2E.Weapons.Aim"}}</th><th>{{localize "SCP2E.Weapons.Recoil"}}</th>
        <th>{{localize "SCP2E.Weapons.BDam"}}</th><th>{{localize "SCP2E.Weapons.XDam"}}</th>
        <th>{{localize "SCP2E.Weapons.Mag"}}</th><th>{{localize "SCP2E.Weapons.Range"}}</th>
        <th>{{localize "SCP2E.Weapons.Mass"}}</th><th>{{localize "SCP2E.Weapons.Note"}}</th><th></th>
      </tr></thead>
      <tbody>
      {{#each data.weapons as |w i|}}
        <tr>
          <td><input type="text" name="flags.scp2e-character-sheet.data.weapons.{{i}}.name" value="{{w.name}}"/></td>
          <td><input type="text" name="flags.scp2e-character-sheet.data.weapons.{{i}}.toHit" value="{{w.toHit}}"/></td>
          <td><input type="text" name="flags.scp2e-character-sheet.data.weapons.{{i}}.aim" value="{{w.aim}}"/></td>
          <td><input type="text" name="flags.scp2e-character-sheet.data.weapons.{{i}}.recoil" value="{{w.recoil}}"/></td>
          <td><input type="text" name="flags.scp2e-character-sheet.data.weapons.{{i}}.bDam" value="{{w.bDam}}"/></td>
          <td><input type="text" name="flags.scp2e-character-sheet.data.weapons.{{i}}.xDam" value="{{w.xDam}}"/></td>
          <td><input type="text" name="flags.scp2e-character-sheet.data.weapons.{{i}}.mag" value="{{w.mag}}"/></td>
          <td><input type="text" name="flags.scp2e-character-sheet.data.weapons.{{i}}.range" value="{{w.range}}"/></td>
          <td><input type="text" name="flags.scp2e-character-sheet.data.weapons.{{i}}.mass" value="{{w.mass}}"/></td>
          <td><input type="text" name="flags.scp2e-character-sheet.data.weapons.{{i}}.note" value="{{w.note}}"/></td>
          <td><button type="button" class="del-row" data-action="deleteWeapon" data-array="weapons" data-index="{{i}}"><i class="fa-solid fa-trash"></i></button></td>
        </tr>
      {{/each}}
      </tbody>
    </table>

    <div class="uniforms">
      <div><label>{{localize "SCP2E.Uniform.AStyle"}}</label>
        <input type="text" name="flags.scp2e-character-sheet.data.uniforms.aStyle" value="{{data.uniforms.aStyle}}"/></div>
      <div><label>{{localize "SCP2E.Uniform.ASus"}}</label>
        <input type="text" name="flags.scp2e-character-sheet.data.uniforms.aSus" value="{{data.uniforms.aSus}}"/></div>
      <div><label>{{localize "SCP2E.Uniform.BStyle"}}</label>
        <input type="text" name="flags.scp2e-character-sheet.data.uniforms.bStyle" value="{{data.uniforms.bStyle}}"/></div>
      <div><label>{{localize "SCP2E.Uniform.BSus"}}</label>
        <input type="text" name="flags.scp2e-character-sheet.data.uniforms.bSus" value="{{data.uniforms.bSus}}"/></div>
    </div>
  </div>
  {{/if}}

  {{!-- ============================ ASPECTS ============================ --}}
  {{#if (eq activeTab "aspects")}}
  <div class="scp2e-aspects">
    <h3>{{localize "SCP2E.Aspects.Title"}}
      <button type="button" class="add-row" data-action="addAspect" data-array="aspects"><i class="fa-solid fa-plus"></i></button>
    </h3>
    <table class="aspects">
      <thead><tr>
        <th>{{localize "SCP2E.Aspects.Name"}}</th><th>{{localize "SCP2E.Aspects.Type"}}</th>
        <th>{{localize "SCP2E.Aspects.Cost"}}</th><th>{{localize "SCP2E.Aspects.Page"}}</th><th></th>
      </tr></thead>
      <tbody>
      {{#each data.aspects as |a i|}}
        <tr>
          <td><input type="text" name="flags.scp2e-character-sheet.data.aspects.{{i}}.name" value="{{a.name}}"/></td>
          <td><select name="flags.scp2e-character-sheet.data.aspects.{{i}}.type">
            <option value="power" {{#if (eq a.type "power")}}selected{{/if}}>{{localize "SCP2E.Aspects.Power"}}</option>
            <option value="talent" {{#if (eq a.type "talent")}}selected{{/if}}>{{localize "SCP2E.Aspects.Talent"}}</option>
            <option value="history" {{#if (eq a.type "history")}}selected{{/if}}>{{localize "SCP2E.Aspects.History"}}</option>
          </select></td>
          <td><input type="text" name="flags.scp2e-character-sheet.data.aspects.{{i}}.cost" value="{{a.cost}}"/></td>
          <td><input type="text" name="flags.scp2e-character-sheet.data.aspects.{{i}}.page" value="{{a.page}}"/></td>
          <td><button type="button" class="del-row" data-action="deleteAspect" data-array="aspects" data-index="{{i}}"><i class="fa-solid fa-trash"></i></button></td>
        </tr>
      {{/each}}
      </tbody>
    </table>

    <h3>{{localize "SCP2E.Departments.Title"}}</h3>
    <div class="departments">
      {{#each departments}}
        <div class="dept"><label>{{key}}</label>
          <input type="number" name="flags.scp2e-character-sheet.data.departments.{{key}}" value="{{value}}"/></div>
      {{/each}}
    </div>

    <h3>{{localize "SCP2E.Field.AspectNotes"}}</h3>
    <textarea class="notes-area" name="flags.scp2e-character-sheet.data.aspectNotes" rows="5">{{data.aspectNotes}}</textarea>
  </div>
  {{/if}}

  {{!-- ============================ NOTES ============================ --}}
  {{#if (eq activeTab "notes")}}
  <div class="scp2e-notes">
    <h3>{{localize "SCP2E.Field.EverydayCarry"}}</h3>
    <textarea class="notes-area" name="flags.scp2e-character-sheet.data.everydayCarry" rows="4">{{data.everydayCarry}}</textarea>
    <h3>{{localize "SCP2E.Field.SmallItems"}}</h3>
    <textarea class="notes-area" name="flags.scp2e-character-sheet.data.smallItems" rows="4">{{data.smallItems}}</textarea>
    <h3>{{localize "SCP2E.Field.Container"}}</h3>
    <textarea class="notes-area" name="flags.scp2e-character-sheet.data.storage" rows="4">{{data.storage}}</textarea>
    <h3>{{localize "SCP2E.Field.MiscNotes"}}</h3>
    <textarea class="notes-area" name="flags.scp2e-character-sheet.data.miscNotes" rows="6">{{data.miscNotes}}</textarea>
  </div>
  {{/if}}

  </section>
</div>
